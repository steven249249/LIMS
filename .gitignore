target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the user is
#   responsible for mapping to their own environment.
# .python-version

# pipenv
#   According to pypa/pipenv#1185, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you choose not to, then uncomment the following line:
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
# pdm.lock
#   pdm stores project-wide configurations in .pdm.toml, but it is recommended to include it.
# .pdm.toml

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

