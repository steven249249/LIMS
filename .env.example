# LIMS production environment template.
#
# Copy this file to `.env` (same directory as docker-compose.yml) and fill in
# real values BEFORE running `docker compose up`. Anything left blank uses the
# default in docker-compose.yml.
#
#     cp .env.example .env
#     # edit .env, then:
#     docker compose --env-file .env up -d --build

# ── Django ──────────────────────────────────────────────────────────────
# Generate a fresh one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# REQUIRED — without it the backend container refuses to start.
DJANGO_SECRET_KEY=replace-me-with-50-byte-random-string

# Comma-separated. Add any additional FQDNs (e.g. www.lims.ddns.net).
DJANGO_ALLOWED_HOSTS=lims.ddns.net

# Comma-separated. Must use https:// because the site is HTTPS-only.
CORS_ALLOWED_ORIGINS=https://lims.ddns.net

# Initial password baked into the auto-provisioned `admin` account on first
# `migrate`. Change after the first login.
LIMS_ADMIN_PASSWORD=Admin@LIMS_2026!Sup

# ── MySQL ───────────────────────────────────────────────────────────────
DB_NAME=lab_booking
DB_USER=lab_user
DB_PASSWORD=replace-me-with-strong-password
MYSQL_ROOT_PASSWORD=replace-me-with-different-strong-password

# ── Caddy / TLS ─────────────────────────────────────────────────────────
# Let's Encrypt sends expiry notices here. Use a real, monitored mailbox.
ADMIN_EMAIL=admin@lims.ddns.net

# ── Sentry (optional) ───────────────────────────────────────────────────
# Leave empty to disable Sentry. When set, the backend ships errors there.
SENTRY_DSN=
