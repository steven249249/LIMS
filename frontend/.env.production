# Vite production environment.
# Loaded automatically by `npm run build` (which is what the Docker
# image uses). Keeps API requests on the same origin, so Caddy
# reverse-proxies them to the Django backend without crossing CORS.
#
# Dev (`npm run dev`) reads .env.development if present, otherwise the
# fallback in src/api/client.js (http://127.0.0.1:8000/api).
VITE_API_BASE=/api
